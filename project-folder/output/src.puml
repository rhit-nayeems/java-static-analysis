  -{static} FIELD_PATTERN: Pattern = Pattern.compile("\\b(?:public|private|protected|static|final)+\\s+(?:int|String|boolean|double|float|long|char|byte|short|void|[a-zA-Z_][a-zA-Z0-9_]*)(?:\\[\\])*\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*[=;]")
  -{static} VARIABLE_PATTERN: Pattern = Pattern.compile("\\b(?:int|String|boolean|double|float|long|char|byte|short|void|[a-zA-Z_][a-zA-Z0-9_]*)(?:\\[\\])*\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*[=;,)]")
  -{static} SNAKE_CASE_PATTERN: Pattern = Pattern.compile("^[a-z][a-z0-9]*(_[a-z0-9]+)*$|^[a-z]$")
  --
  #lintFile(file: File, content: String, violations: StringBuilder): void
  -isSnakeCaseViolation(identifier: String): boolean
  -isKeywordOrType(word: String): boolean
}

