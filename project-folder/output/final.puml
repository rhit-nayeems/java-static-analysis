
@startuml

package domain {
  abstract class AbstractASMLinter {

    #asmReader: ASMReader
    --
    +AbstractASMLinter(asmReader: ASMReader)
    +AbstractASMLinter()
    +lint(files: List<File>): String
    #lintClass(classNode: ClassNode, allClasses: List<ClassNode>, result: StringBuilder): int
    #getNoViolationsMessage(): String
    #getViolationsMessage(violationCount: int, result: StringBuilder): String
    #preProcessClasses(classes: List<ClassNode>): void
    #isSkippableClass(classNode: ClassNode): boolean
  }

  abstract class AbstractSourceLinter {

    +lint(files: List<File>): String
    -processDirectory(dir: File, violations: StringBuilder): void
    -processJavaFile(file: File, violations: StringBuilder): void
    #lintFile(file: File, content: String, violations: StringBuilder): void
    #removeComments(line: String): String
  }

  class AdapterPatternLinter {
    +AdapterPatternLinter()
    +AdapterPatternLinter(asmReader: ASMReader)
    #lintClass(classNode: ClassNode, allClasses: List<ClassNode>, result: StringBuilder): int
    -analyzeClass(classNode: ClassNode): AdapterCandidate
    -collectTargetTypes(classNode: ClassNode): Set<String>
    -collectAdapteeFieldTypes(classNode: ClassNode): Set<String>
    -collectDelegatedOwners(method: MethodNode, adapteeFieldTypes: Set<String>): Set<String>
    -isSkippableMethod(method: MethodNode): boolean
    -appendCandidate(result: StringBuilder, candidate: AdapterCandidate): void
    -formatTypes(types: Set<String>): String
    #getNoViolationsMessage(): String
    #getViolationsMessage(violationCount: int, result: StringBuilder): String
  }

  class AdapterCandidate {
    -className: String
    -targetTypes: Set<String>
    -adapteeFieldTypes: Set<String>
    -delegatedOwners: Set<String>
    -isAdapter: boolean
    --
    -AdapterCandidate(className: String, targetTypes: Set<String>, adapteeFieldTypes: Set<String>, delegatedOwners: Set<String>, isAdapter: boolean)
  }

  class BooleanFlagMethodLinter {
    -asmReader: ASMReader
    --
    +BooleanFlagMethodLinter()
    +BooleanFlagMethodLinter(asmReader: ASMReader)
    +lint(files: List<File>): String
    -isSkippableMethod(method: MethodNode): boolean
    -countBooleanParameters(argumentTypes: Type[]): int
  }

  class DecoratorPatternLinter {
    +DecoratorPatternLinter()
    +DecoratorPatternLinter(asmReader: ASMReader)
    #lintClass(classNode: ClassNode, allClasses: List<ClassNode>, result: StringBuilder): int
    -hasFieldOfType(classNode: ClassNode, typeInternalName: String): boolean
    -reportDecorator(classNode: ClassNode, decoratedTypes: List<String>, result: StringBuilder): void
    #getNoViolationsMessage(): String
    #getViolationsMessage(violationCount: int, result: StringBuilder): String
  }

  class DesignRiskLinter {
    -lcomCalculator: LCOMCalculator
    --
    +DesignRiskLinter(asmReader: ASMReader, lcomCalculator: LCOMCalculator)
    +DesignRiskLinter()
    #lintClass(classNode: ClassNode, allClasses: List<ClassNode>, result: StringBuilder): int
    -getRiskLevel(score: int): String
    -addTypeToDependencies(type: Type, dependencies: Set<String>): void
    #getNoViolationsMessage(): String
  }

  class FacadePatternLinter {
    -internalClassNames: Set<String>
    --
    +FacadePatternLinter()
    +FacadePatternLinter(asmReader: ASMReader)
    #preProcessClasses(classes: List<ClassNode>): void
    #lintClass(classNode: ClassNode, allClasses: List<ClassNode>, result: StringBuilder): int
    -analyzeCandidate(classNode: ClassNode, internalClassNames: Set<String>): FacadeCandidate
    -collectFieldSubsystems(classNode: ClassNode, internalClassNames: Set<String>): Set<String>
    -collectInvokedInternalTypes(method: MethodNode, ownerName: String, internalClassNames: Set<String>): Set<String>
    -extractObjectTypes(descriptor: String): List<String>
    -extractObjectTypes(type: Type, types: List<String>): void
    -isPublicBusinessMethod(method: MethodNode): boolean
    -appendCandidate(result: StringBuilder, candidate: FacadeCandidate): void
    -formatTypeSet(typeNames: Set<String>): String
    #getNoViolationsMessage(): String
    #getViolationsMessage(violationCount: int, result: StringBuilder): String
  }

  class FacadeCandidate {
    -className: String
    -publicMethodCount: int
    -delegatingPublicMethodCount: int
    -fieldSubsystems: Set<String>
    -invokedSubsystems: Set<String>
    -isFacade: boolean
    --
    -FacadeCandidate(className: String, publicMethodCount: int, delegatingPublicMethodCount: int, fieldSubsystems: Set<String>, invokedSubsystems: Set<String>, isFacade: boolean)
  }

  class LCOMCalculator {
    +calculateLCOM(classNode: ClassNode): LCOMResult
    -getInstanceMethods(classNode: ClassNode): List<MethodNode>
    -getInstanceFields(classNode: ClassNode): List<FieldNode>
    -buildMethodFieldAccessMap(classNode: ClassNode, methods: List<MethodNode>, fields: List<FieldNode>): Map<String,Set<String>>
    -findConnectedComponents(methods: List<MethodNode>, methodFieldAccess: Map<String,Set<String>>): List<Set<String>>
  }

  class LCOMResult {
    -className: String
    -lcomScore: int
    -methodCount: int
    -fieldCount: int
    -components: List<Set<String>>
    --
    +LCOMResult(className: String, lcomScore: int, methodCount: int, fieldCount: int, components: List<Set<String>>)
    +getClassName(): String
    +getLcomScore(): int
    +getMethodCount(): int
    +getFieldCount(): int
    +getComponents(): List<Set<String>>
    +hasLowCohesion(threshold: int): boolean
  }

  class UnionFind {
    ~find(method: String): String
    ~union(method1: String, method2: String): void
  }

  class LeastKnowledgePrincipleLinter {
    -{static} TYPE_DECLARATION: Pattern = Pattern.compile("\\b(class|interface|enum|record)\\b")
    -{static} METHOD_CHAIN_AFTER_CALL: Pattern = Pattern.compile("\\)\\s*\\.")
    -{static} MULTI_DOT_CHAIN: Pattern = Pattern.compile("\\b[A-Za-z_$][\\w$]*\\s*\\.\\s*[A-Za-z_$][\\w$]*\\s*\\.\\s*[A-Za-z_$]")
    --
    +lint(files: List<File>): String
    -findDemeterViolations(file: File): List<Integer>
    -isDemeterViolation(statement: String): boolean
    -removeComments(line: String, inBlockComment: boolean[]): String
  }

  interface Linter {
    ~lint(files: List<File>): String
  }

  class LinterConfig {
    +{static} DEFAULT_TOO_MANY_PARAMETERS_LIMIT: int = 5
    +{static} DEFAULT_SRP_LCOM_THRESHOLD: int = 2
    -enabledLinters: Set<String>
    -tooManyParametersLimit: int
    -srpLcomThreshold: int
    --
    +LinterConfig(enabledLinters: Set<String>, tooManyParametersLimit: int, srpLcomThreshold: int)
    +{static} defaultConfig(): LinterConfig
    +isLinterEnabled(linterType: Class<? extends Linter>): boolean
    +getTooManyParametersLimit(): int
    +getSrpLcomThreshold(): int
    +getEnabledLinters(): Set<String>
    -normalizeEnabledLinters(linters: Set<String>): Set<String>
    -{static} normalize(value: String): String
  }

  class PlantUMLGenerator {
    -asmReader: ASMReader
    --
    +PlantUMLGenerator()
    +lint(files: List<File>): String
    -generateClassDiagram(classNode: ClassNode, output: StringBuilder): void
    -generateRelationships(classNode: ClassNode, output: StringBuilder, allClasses: List<ClassNode>): void
    -extractClassName(fullName: String): String
    -extractTypeName(descriptor: String): String
    -extractReturnType(methodDescriptor: String): String
    -extractParameters(methodDescriptor: String): String
    -getAccessModifier(access: int): String
  }

  class PublicNonFinalFieldLinter {
    +PublicNonFinalFieldLinter()
    +PublicNonFinalFieldLinter(asmReader: ASMReader)
    #lintClass(classNode: ClassNode, allClasses: List<ClassNode>, result: StringBuilder): int
    #getNoViolationsMessage(): String
    #getViolationsMessage(violationCount: int, result: StringBuilder): String
  }

  class SingletonPatternLinter {
    +SingletonPatternLinter()
    +SingletonPatternLinter(asmReader: ASMReader)
    #lintClass(classNode: ClassNode, allClasses: List<ClassNode>, result: StringBuilder): int
    -hasPrivateConstructors(classNode: ClassNode): boolean
    -findSingletonField(classNode: ClassNode): FieldNode
    -hasPublicStaticAccessor(classNode: ClassNode, singletonField: FieldNode): boolean
    -loadsSingletonField(classNode: ClassNode, singletonField: FieldNode, method: MethodNode): boolean
    #getNoViolationsMessage(): String
    #getViolationsMessage(violationCount: int, result: StringBuilder): String
  }

  class SnakeLinter {
    -{static} CLASS_PATTERN: Pattern = Pattern.compile("\\b(?:public|private|protected)?\\s*(?:abstract)?\\s*class\\s+([a-zA-Z_][a-zA-Z0-9_]*)")
    -{static} FIELD_PATTERN: Pattern = Pattern.compile("\\b(?:public|private|protected|static|final)+\\s+(?:int|String|boolean|double|float|long|char|byte|short|void|[a-zA-Z_][a-zA-Z0-9_]*)(?:\\[\\])*\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*[=;]")
    -{static} VARIABLE_PATTERN: Pattern = Pattern.compile("\\b(?:int|String|boolean|double|float|long|char|byte|short|void|[a-zA-Z_][a-zA-Z0-9_]*)(?:\\[\\])*\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*[=;,)]")
    -{static} SNAKE_CASE_PATTERN: Pattern = Pattern.compile("^[a-z][a-z0-9]*(_[a-z0-9]+)*$|^[a-z]$")
    --
    #lintFile(file: File, content: String, violations: StringBuilder): void
    -isSnakeCaseViolation(identifier: String): boolean
    -isKeywordOrType(word: String): boolean
  }

  class SRPLinter {
    -{static} DEFAULT_LCOM_THRESHOLD: int = 2
    -lcomThreshold: int
    -lcomCalculator: LCOMCalculator
    --
    +SRPLinter(asmReader: ASMReader, lcomCalculator: LCOMCalculator)
    +SRPLinter(lcomThreshold: int, asmReader: ASMReader, lcomCalculator: LCOMCalculator)
    #lintClass(classNode: ClassNode, allClasses: List<ClassNode>, result: StringBuilder): int
    -appendViolation(result: StringBuilder, classNode: ClassNode, lcomResult: LCOMCalculator.LCOMResult): void
    -formatMethodList(methods: java.util.Set<String>): String
    #getNoViolationsMessage(): String
    #getViolationsMessage(violationCount: int, result: StringBuilder): String
  }

  class StrategyPatternLinter {
    -interfaceToImplementors: Map<String, Set<String>> = new HashMap<>()
    -internalClassNames: Set<String> = new HashSet<>()
    --
    +StrategyPatternLinter()
    +StrategyPatternLinter(asmReader: ASMReader)
    #preProcessClasses(classes: List<ClassNode>): void
    #lintClass(classNode: ClassNode, allClasses: List<ClassNode>, result: StringBuilder): int
    -analyzeClass(classNode: ClassNode): StrategyCandidate
    -isSkippableMethod(method: MethodNode): boolean
    -collectFieldTypes(classNode: ClassNode): Set<String>
    -collectObjectTypes(t: Type, types: Set<String>): void
    -appendCandidate(result: StringBuilder, candidate: StrategyCandidate): void
    #getNoViolationsMessage(): String
    #getViolationsMessage(violationCount: int, result: StringBuilder): String
  }

  class StrategyCandidate {
    -className: String
    -interfaceName: String
    -implementations: Set<String>
    -isStrategy: boolean
    --
    -StrategyCandidate(className: String, interfaceName: String, implementations: Set<String>, isStrategy: boolean)
  }

  class TooManyParametersLinter {
    -{static} DEFAULT_PARAMETER_LIMIT: int = 5
    -parameterLimit: int
    --
    +TooManyParametersLinter()
    +TooManyParametersLinter(parameterLimit: int)
    +TooManyParametersLinter(parameterLimit: int, asmReader: ASMReader)
    #lintClass(classNode: ClassNode, allClasses: List<ClassNode>, result: StringBuilder): int
    -isSkippableMethod(method: MethodNode): boolean
    #getNoViolationsMessage(): String
    #getViolationsMessage(violationCount: int, result: StringBuilder): String
  }

  class TrailingWhitespaceLinter {
    +lint(files: List<File>): String
    -findTrailingWhitespaceLines(file: File): List<Integer>
    -hasTrailingWhitespace(line: String): boolean
  }

  class UnusedImportLinter {
    #lintFile(file: File, content: String, violations: StringBuilder): void
  }

  class ImportInfo {
    ~simpleName: String
    ~fullPath: String
    ~lineNumber: int
    --
    ~ImportInfo(simpleName: String, fullPath: String, lineNumber: int)
  }
}

package datastorage{
  class ASMReader {
    +readClassFile(classFile: File): ClassNode
    +getFields(classFile: File): List<FieldNode>
    +getMethods(classFile: File): List<MethodNode>
    +getClasses(files: List<File>): List<ClassNode>
    -recurseFiles(file: File, classes: List<ClassNode>): void
    +getAllMethods(files: List<File>): List<MethodNode>
  }

  class ConfigLoader {
    +loadConfig(path: String): LinterConfig
    -parseEnabledLinters(value: String): Set<String>
    -parsePositiveInt(value: String, defaultValue: int): int
  }

  class FileLoader {
  -file: File
  --
  +loadFiles(input: String): List<File>
  +getFile(): File
  -expandInputFiles(requestedPaths: List<File>): List<File>
  -collectFiles(path: File, files: List<File>, seenPaths: Set<String>): void
}
}

package presentation{
class LinterFactory {
  +createLinters(config: LinterConfig): List<Linter>
  -addIfEnabled(linters: List<Linter>, linter: Linter, linterType: Class<? extends Linter>, config: LinterConfig): void
}

class LinterMain {
  -{static} DEFAULT_CONFIG_PATH: String = "linter.properties"
  -availableLinters: List<Linter>
  -fileLoader: FileLoader
  -configLoader: ConfigLoader
  -scanner: Scanner
  -linterFactory: LinterFactory
  -linterRunner: LinterRunner
  --
  +LinterMain()
  +{static} main(args: String[]): void
  +run(): void
  -askForFileInput(): String
  -displayResult(result: String): void
}

class LinterRunner {
  -{static} CLASS_FILE_LINTER_TYPES: List<Class<? extends Linter>> = List.of(SRPLinter.class, FacadePatternLinter.class, StrategyPatternLinter.class, SingletonPatternLinter.class, DecoratorPatternLinter.class, AdapterPatternLinter.class, BooleanFlagMethodLinter.class, PublicNonFinalFieldLinter.class, TooManyParametersLinter.class, PlantUMLGenerator.class, DesignRiskLinter.class)
  -{static} NON_CLASS_FILE_LINTER_TYPES: List<Class<? extends Linter>> = List.of(SnakeLinter.class, UnusedImportLinter.class, TrailingWhitespaceLinter.class)
  --
  +run(files: List<File>, availableLinters: List<Linter>): String

  -splitFilesByType(files: List<File>, classFiles: List<File>, nonClassFiles: List<File>): void
  -isClassFile(file: File): boolean
  -runLintBatches(classFiles: List<File>, nonClassFiles: List<File>, availableLinters: List<Linter>): String
  -selectLinters(linterTypes: List<Class<? extends Linter>>, availableLinters: List<Linter>): List<Linter>
  -runLinters(linters: List<Linter>, files: List<File>): String
}
}
ConfigLoader ..> LinterConfig

AbstractASMLinter ..|> Linter
AbstractASMLinter .d.> ASMReader

AbstractSourceLinter ..|> Linter

AdapterPatternLinter --|> AbstractASMLinter
AdapterPatternLinter ..> AdapterCandidate
AdapterPatternLinter ..> ASMReader

BooleanFlagMethodLinter ..|> Linter
BooleanFlagMethodLinter ..> ASMReader

DecoratorPatternLinter --|> AbstractASMLinter
DecoratorPatternLinter ..> ASMReader

DesignRiskLinter --|> AbstractASMLinter
DesignRiskLinter ..> LCOMCalculator
DesignRiskLinter ..> ASMReader

FacadePatternLinter --|> AbstractASMLinter
FacadePatternLinter ..> FacadeCandidate
FacadePatternLinter ..> ASMReader

LCOMCalculator ..> LCOMResult

LeastKnowledgePrincipleLinter ..|> Linter

PlantUMLGenerator ..|> Linter
PlantUMLGenerator ..> ASMReader

PublicNonFinalFieldLinter --|> AbstractASMLinter
PublicNonFinalFieldLinter ..> ASMReader

SingletonPatternLinter --|> AbstractASMLinter
SingletonPatternLinter ..> ASMReader

SnakeLinter --|> AbstractSourceLinter

SRPLinter --|> AbstractASMLinter
SRPLinter ..> LCOMCalculator
SRPLinter ..> LCOMResult
SRPLinter ..> ASMReader

StrategyPatternLinter --|> AbstractASMLinter
StrategyPatternLinter ..> StrategyCandidate
StrategyPatternLinter ..> ASMReader

TooManyParametersLinter --|> AbstractASMLinter
TooManyParametersLinter ..> ASMReader

TrailingWhitespaceLinter ..|> Linter

UnusedImportLinter --|> AbstractSourceLinter

LinterFactory ..> LinterConfig
LinterFactory ..> Linter

LinterMain o-- Linter
LinterMain ..> FileLoader
LinterMain ..> ConfigLoader
LinterMain ..> LinterFactory
LinterMain ..> LinterRunner


note right of domain.AbstractASMLinter: Template Method Pattern
note right of domain.AbstractSourceLinter: Template Method Pattern
note right of domain.Linter: Strategy Pattern Interface
note top of presentation: we use three layer architecture (presentation, domain, datastorage)

note top of datastorage.ASMReader: Adapter Pattern (Adapts ASM library)
note top of presentation.LinterRunner: Facade Pattern
note top of domain.SRPLinter: Single Responsibility Principle
note top of presentation.LinterMain: Principle of Least Knowledge (Uses Factory, doesn't build Linters)
note bottom of domain.AbstractASMLinter: Hollywood Principle (Parent calls Child)

@enduml